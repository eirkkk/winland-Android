# Winland Server - ARM64 Build Environment Configuration
# Copy this file to .env and update with your paths

# ========== Rust Configuration ==========
# Location of Rust toolchain
RUST_HOME=$HOME/.rustup
CARGO_HOME=$HOME/.cargo

# Rust target for ARM64 Android
RUST_TARGET=aarch64-linux-android

# ========== Android SDK/NDK Configuration ==========
# Android SDK root directory
ANDROID_SDK_ROOT=$HOME/Android/Sdk

# Android NDK version and path
ANDROID_NDK_VERSION=25.2.9519653
ANDROID_NDK=$ANDROID_SDK_ROOT/ndk/$ANDROID_NDK_VERSION

# Kotlin/Java version
JAVA_HOME=${JAVA_HOME:-/usr/lib/jvm/java-17-openjdk-amd64}

# ========== Build Configuration ==========
# Gradle build type
GRADLE_BUILD_TYPE=release

# Build jobs (parallel compilation)
BUILD_JOBS=4

# Optimization level (0-3)
OPTIMIZATION_LEVEL=3

# Enable LTO (Link Time Optimization)
ENABLE_LTO=true

# Enable NEON support for ARM64
ENABLE_NEON=true

# ========== Output Configuration ==========
# Output directory for APK
APK_OUTPUT_DIR=app/build/outputs/apk/release

# Verbose output
VERBOSE=false

# Keep build artifacts
KEEP_BUILD_ARTIFACTS=true

# ========== Debugging Configuration ==========
# Enable debug symbols
DEBUG_SYMBOLS=false

# Strip symbols from release
STRIP_SYMBOLS=true

# ========== Network Configuration ==========
# Gradle offline mode
GRADLE_OFFLINE=false

# Retry network operations
NETWORK_RETRY=3
